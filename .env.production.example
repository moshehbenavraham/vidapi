# Production-like Docker Compose environment template.
# Copy this file to .env.production and replace every change-me value before use.
# The API key hash below is for the literal sample key: change-me-api-key

APP_NAME=VidAPI
APP_VERSION=0.1.37
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://vidapi:change-me-postgres@postgres:5432/vidapi
DATABASE_AUTO_CREATE=false
DATABASE_CONNECT_TIMEOUT_SECONDS=10
DATABASE_CONNECT_RETRIES=3
DATABASE_CONNECT_RETRY_BACKOFF_SECONDS=0.5
POSTGRES_USER=vidapi
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=vidapi

RENDER_MODE=async
REDIS_URL=redis://:change-me-redis@redis:6379/0
REDIS_PASSWORD=change-me-redis
REDIS_QUEUE_NAME=arq:queue
REDIS_REQUIRE_AUTH_IN_PRODUCTION=true
# Local production-like Compose uses Redis AUTH on a private bridge, not TLS.
REDIS_REQUIRE_TLS_IN_PRODUCTION=false
MAX_ASYNC_QUEUE_DEPTH=1000
QUEUE_ADMISSION_TIMEOUT_SECONDS=1
QUEUE_RETRY_AFTER_SECONDS=10

API_KEY_AUTH_ENABLED=true
API_KEY_HASHES=484857e0d4a4490864c93593fdaf3e5cd43777320992bf42db949c6ec571dd25
ALLOWED_HOSTS=["localhost","127.0.0.1","api","testserver"]
CORS_ORIGINS=["http://localhost","http://localhost:8000"]

STORAGE_BACKEND=s3
STORAGE_URL_MODE=proxy
STORAGE_ROOT=data
RENDER_WORKSPACE_ROOT=data/renders
ASSET_CACHE_ROOT=data/assets
STORAGE_SIGNED_URL_EXPIRY_SECONDS=900

S3_BUCKET=vidapi-renders
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=vidapi-minio
S3_SECRET_ACCESS_KEY=change-me-minio
S3_OBJECT_PREFIX=renders
S3_FORCE_PATH_STYLE=true
S3_CONNECT_TIMEOUT_SECONDS=5
S3_READ_TIMEOUT_SECONDS=60
S3_MAX_ATTEMPTS=3

MINIO_ROOT_USER=vidapi-minio
MINIO_ROOT_PASSWORD=change-me-minio

MAX_REQUEST_BODY_BYTES=2097152
MAX_RENDER_REQUEST_BODY_BYTES=2097152
MAX_TEMPLATE_REQUEST_BODY_BYTES=2097152
MAX_RENDER_DURATION_SECONDS=120
MAX_OUTPUT_WIDTH=1920
MAX_OUTPUT_HEIGHT=1920
MAX_FPS=60
MAX_CLIPS_PER_RENDER=50
MAX_TRACKS_PER_RENDER=50
MAX_ASSETS_PER_RENDER=100
MAX_ASSET_SIZE_MB=500
MAX_MEDIA_DURATION_SECONDS=600
MAX_MEDIA_WIDTH=3840
MAX_MEDIA_HEIGHT=3840
MAX_MEDIA_STREAMS_PER_ASSET=8

ASSET_DOWNLOAD_TIMEOUT_SECONDS=60
ASSET_MAX_REDIRECTS=5
ASSET_ALLOW_HTTP=false
FFPROBE_TIMEOUT_SECONDS=30
EDITLY_TIMEOUT_SECONDS=600
RENDER_TIMEOUT_SECONDS=600
SUBPROCESS_KILL_GRACE_SECONDS=5
MAX_SUBPROCESS_STDERR_BYTES=1048576

WORKSPACE_CLEANUP_ENABLED=true
WORKSPACE_CLEANUP_KEEP_ON_FAILURE=true
WORKSPACE_ORPHAN_TTL_SECONDS=86400

WEBHOOK_SECRET=change-me-webhook-secret
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAYS=[1,10,60]

RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_RENDER_CREATE=10/minute
RATE_LIMIT_STORAGE_URI=memory://
