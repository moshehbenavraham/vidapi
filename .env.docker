DATABASE_URL=sqlite+aiosqlite:///./data/vidapi.db
REDIS_URL=redis://redis:6379
RENDER_MODE=async
LOG_LEVEL=INFO
DEBUG=false

STORAGE_ROOT=data
RENDER_WORKSPACE_ROOT=data/renders
ASSET_CACHE_ROOT=data/assets

WORKSPACE_CLEANUP_ENABLED=true
WORKSPACE_CLEANUP_KEEP_ON_FAILURE=true

EDITLY_BIN=editly
FFMPEG_BIN=ffmpeg

MAX_RENDER_DURATION_SECONDS=120
RENDER_TIMEOUT_SECONDS=600
