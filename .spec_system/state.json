{
  "version": "2.0",
  "project_name": "VidAPI",
  "description": "Self-hosted Python FastAPI service that replicates Creatomate/JSON2Video behavior - accepts JSON timeline compositions and renders video via FFmpeg",
  "current_phase": 4,
  "current_session": null,
  "monorepo": false,
  "phases": {
    "0": {
      "name": "Foundation",
      "description": "Prove the core JSON-to-video loop locally with FastAPI, Pydantic schema, Editly renderer, and synchronous render service",
      "status": "complete",
      "session_count": 5
    },
    "1": {
      "name": "Async Jobs and Multi-track",
      "description": "Move rendering to async ARQ workers, implement full status state machine with progress, job cancellation, multi-track compositing with z-order, audio mixing, and Docker Compose stack",
      "status": "complete",
      "session_count": 5
    },
    "2": {
      "name": "Templates and Polish",
      "description": "Template CRUD with immutable versioning, Jinja2 variable substitution, webhook callbacks with HMAC signing and retry, named positions and offsets, and basic fade/crossfade transitions",
      "status": "complete",
      "session_count": 5
    },
    "3": {
      "name": "Production Hardening",
      "description": "PostgreSQL persistence and migrations, S3-compatible storage, API key authentication, production limits and resource controls, operational visibility, and production-like Docker Compose stack",
      "status": "complete",
      "session_count": 5
    },
    "4": {
      "name": "Advanced Rendering",
      "description": "Renderer capability validation, advanced output formats and presets, captions and poster controls, additional transitions, native FFmpeg subset, and HyperFrames adapter",
      "status": "in_progress",
      "session_count": 6
    }
  },
